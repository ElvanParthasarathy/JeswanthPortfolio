---
---
<header class="relative h-screen w-full flex flex-col justify-center items-center overflow-hidden bg-black" data-bg-color="#000000" data-text-color="#ffffff">
    <!-- Smooth ambient glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-white opacity-5 blur-[150px] rounded-full pointer-events-none"></div>

    <div class="z-10 text-center space-y-6 relative">
        <p class="text-white/50 tracking-[0.4em] text-xs md:text-sm font-semibold uppercase animate-pulse">Master Editor</p>
        
        <h1 class="text-6xl md:text-8xl font-primary font-bold leading-tight tracking-tighter text-white">
            <span class="block reveal-text">Jeswanth S</span>
            <span class="block reveal-text text-white/30 text-2xl md:text-3xl mt-4 font-normal tracking-[0.3em] uppercase">TJ Cutz</span>
        </h1>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-12 animate-bounce opacity-50">
        <div class="w-6 h-10 border-2 border-white rounded-full flex justify-center pt-2">
            <div class="w-1 h-2 bg-white rounded-full"></div>
        </div>
    </div>
</header>

<script>
    import { gsap } from 'gsap';
    
    // TEXT REVEAL ANIMATIONS
    gsap.from(".reveal-text", {
        y: 60,
        opacity: 0,
        duration: 1.5,
        stagger: 0.2,
        ease: "power4.out",
        delay: 0.5
    });
</script>
