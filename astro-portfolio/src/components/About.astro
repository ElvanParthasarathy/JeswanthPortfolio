---
---
<section id="about" class="py-32 relative overflow-hidden bg-[#181818]" data-bg-color="#252526" data-text-color="#E0E0E0">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-12 gap-12 items-start relative z-10">
        
        <div class="md:col-span-5 relative editor-panel p-6 shadow-xl border border-gray-700 rounded-sm">
            <div class="border-b border-gray-700 pb-2 mb-4 flex justify-between items-center">
                <span class="font-mono text-xs text-editor-muted uppercase tracking-widest">Inspector / Source</span>
                <div class="flex gap-1">
                    <div class="w-2 h-2 rounded-full bg-gray-600"></div>
                    <div class="w-2 h-2 rounded-full bg-gray-600"></div>
                </div>
            </div>
            <div class="aspect-[3/4] bg-[#1E1E1E] border border-gray-700 flex flex-col items-center justify-center p-8 text-center shadow-inner relative overflow-hidden hover:border-editor-accent transition-colors duration-300">
                <div class="absolute inset-0 z-0 opacity-10" style="background-size: 20px 20px; background-image: linear-gradient(to right, #333 1px, transparent 1px), linear-gradient(to bottom, #333 1px, transparent 1px);"></div>
                <div class="z-10 flex flex-col items-center justify-center">
                    <svg class="w-16 h-16 text-editor-muted mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                    <span class="text-editor-muted font-mono text-xs uppercase block">[ Media Offline ]</span>
                    <span class="text-gray-500 font-mono text-[10px] mt-2 block">Link Photo of Jeswanth S</span>
                </div>
            </div>
        </div>

        <div class="md:col-span-7 space-y-8 editor-panel p-8 shadow-xl border border-gray-700 rounded-sm">
            <div class="flex items-center gap-2 border-b border-gray-700 pb-4">
                <div class="w-2 h-4 bg-editor-accent"></div>
                <h2 class="text-2xl font-mono font-bold uppercase text-white">Properties</h2>
            </div>
            
            <div class="space-y-6 font-mono text-sm">
                
                <div class="grid grid-cols-3 border-b border-gray-800 pb-3">
                    <span class="text-editor-muted col-span-1">Name</span>
                    <span class="text-white col-span-2 font-bold text-lg">Jeswanth S <span class="text-editor-accent text-sm">(TJ Cutz)</span></span>
                </div>
                
                <div class="grid grid-cols-3 border-b border-gray-800 pb-3">
                    <span class="text-editor-muted col-span-1">Degree</span>
                    <span class="text-white col-span-2">Bachelor Of Engineering</span>
                </div>
                
                <div class="grid grid-cols-3 border-b border-gray-800 pb-3">
                    <span class="text-editor-muted col-span-1">Department</span>
                    <span class="text-white col-span-2">Final year ECE dept</span>
                </div>
                
                <div class="grid grid-cols-3 border-b border-gray-800 pb-3">
                    <span class="text-editor-muted col-span-1">Institution</span>
                    <span class="text-white col-span-2">RMD ENGINEERING COLLEGE</span>
                </div>
                
                <div class="grid grid-cols-3 border-b border-gray-800 pb-3">
                    <span class="text-editor-muted col-span-1">Bio</span>
                    <span class="text-gray-400 col-span-2 leading-relaxed">The creator behind the brand TJ CUTZ. Started in 2020 editing on mobile. Now mastering CapCut PC & Premiere Pro to create visuals that get fans screaming in theatres.</span>
                </div>
            </div>

            <div class="pt-4">
                <h3 class="text-xs font-bold tracking-widest uppercase mb-4 text-editor-muted font-mono">Software Arsenal Tracks</h3>
                <div class="flex flex-col gap-2">
                    <div class="flex items-center gap-4 bg-[#1E1E1E] p-2 border border-gray-700">
                        <span class="bg-editor-accent text-black text-xs font-bold px-2 py-1">V1</span>
                        <span class="text-sm font-bold text-white">CAPCUT PC (PRO)</span>
                    </div>
                    <div class="flex items-center gap-4 bg-[#1E1E1E] p-2 border border-gray-700">
                        <span class="bg-editor-red text-white text-xs font-bold px-2 py-1">V2</span>
                        <span class="text-sm font-bold text-white">PREMIERE PRO</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    
    gsap.registerPlugin(ScrollTrigger);

    // ABOUT SECTION PARALLAX
    gsap.from("#about .editor-panel", {
        scrollTrigger: {
            trigger: "#about",
            start: "top 75%",
        },
        y: 50,
        opacity: 0,
        duration: 1,
        stagger: 0.2,
        ease: "power2.out"
    });
</script>
