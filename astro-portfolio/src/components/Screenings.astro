---
import videos from '../data/videos.json';
---
<section id="work" class="py-32 px-6 relative editor-panel mx-2 my-20 rounded-lg shadow-2xl" data-bg-color="#181818" data-text-color="#E0E0E0">
    <div class="max-w-7xl mx-auto">
        <!-- Panel Header -->
        <div class="flex items-center justify-between mb-12 border-b border-gray-700 pb-4">
            <div class="flex items-center gap-4">
                <div class="flex gap-2">
                    <div class="w-3 h-3 rounded-full bg-editor-red"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                    <div class="w-3 h-3 rounded-full bg-green-500"></div>
                </div>
                <h2 class="text-2xl md:text-3xl font-primary font-bold tracking-tight text-white">Project Bin: <span class="text-editor-accent">THEATRE_SCREENINGS</span></h2>
            </div>
            <p class="hidden md:block font-mono text-sm text-editor-muted">ITEMS: {videos.length}</p>
        </div>

        <!-- Video Grid / Media Pool -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
            {videos.map((video, index) => (
                <div class="group project-card cursor-none bg-[#1E1E1E] border border-gray-700 rounded-sm overflow-hidden hover:border-editor-accent transition-colors duration-300">
                    <!-- Video Container -->
                    <div class="aspect-video w-full relative play-trigger bg-black overflow-hidden flex items-center justify-center">
                        <!-- We use actual video tag pointing to the URL -->
                        <video 
                            src={video.video_url} 
                            class="w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-opacity duration-500" 
                            muted 
                            loop 
                            playsinline
                            onmouseover="this.play()" 
                            onmouseout="this.pause()">
                        </video>
                        <div class="absolute bottom-2 right-2 bg-black/80 px-2 py-1 rounded-sm border border-gray-700 font-mono text-[10px] text-editor-muted">
                            [ {video.date} ]
                        </div>
                    </div>
                    
                    <!-- Clip Metadata -->
                    <div class="p-4 bg-[#252526] border-t border-gray-700">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="text-lg font-primary font-bold text-white leading-tight uppercase">{video.title}</h3>
                            <span class="font-mono text-[10px] text-editor-accent bg-editor-accent/10 px-2 py-1 rounded-sm">{video.event}</span>
                        </div>
                        <div class="flex items-center gap-2 mt-3 text-editor-muted font-mono text-xs">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            <span class="truncate">{video.theatre}</span>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    
    gsap.registerPlugin(ScrollTrigger);
    
    // PROJECT CARD FADE IN
    const projects = document.querySelectorAll('.project-card');
    projects.forEach((project, i) => {
        gsap.from(project, {
            scrollTrigger: {
                trigger: project,
                start: "top 85%",
                toggleActions: "play none none reverse"
            },
            y: 30,
            opacity: 0,
            duration: 0.6,
            delay: i % 2 === 0 ? 0 : 0.1
        });
    });
</script>
