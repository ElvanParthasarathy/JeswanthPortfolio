---
<section id="contact" class="min-h-[70vh] flex flex-col justify-between py-20 px-6 relative bg-editor-bg" data-bg-color="#181818" data-text-color="#E0E0E0">
    <div class="max-w-7xl mx-auto w-full h-full flex flex-col justify-center items-center text-center flex-grow editor-panel p-12 border border-gray-700 rounded-sm shadow-2xl relative overflow-hidden">
        
        <!-- Render status bar -->
        <div class="absolute top-0 left-0 w-full h-1 bg-gray-800">
            <div class="h-full bg-editor-accent w-1/3 animate-pulse"></div>
        </div>

        <p class="text-editor-accent font-mono text-sm tracking-[0.2em] mb-6 border border-editor-accent px-4 py-1 rounded-sm bg-editor-accent/10">EXPORT SEQUENCE</p>
        
        <h2 class="text-4xl md:text-6xl font-primary font-bold uppercase mb-8 text-white">
            WANT TO SCREEN A <span class="text-transparent bg-clip-text bg-gradient-to-r from-editor-red to-editor-accent">MASHUP?</span>
        </h2>
        
        <div class="flex flex-col md:flex-row gap-6 mb-12 w-full max-w-xl justify-center">
            <!-- Mail Button -->
            <a href="mailto:jeswanths123@gmail.com" class="flex-1 flex items-center justify-center gap-3 px-8 py-4 bg-white text-black font-bold uppercase tracking-wider hover:bg-gray-200 transition-colors rounded-sm group">
                <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                RENDER_MAIL
            </a>
            
            <!-- Instagram Button -->
            <a href="https://instagram.com/tj_cutz" target="_blank" class="flex-1 flex items-center justify-center gap-3 px-8 py-4 bg-[#1E1E1E] text-white border border-gray-600 font-bold uppercase tracking-wider hover:border-editor-accent hover:text-editor-accent transition-colors rounded-sm group">
                <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                INSTAGRAM
            </a>
        </div>
        
    </div>
    
    <footer class="w-full flex justify-between items-center pt-8 mt-12 border-t border-gray-800 text-xs font-mono text-editor-muted">
        <p>&copy; {new Date().getFullYear()} TJ CUTZ. ALL RIGHTS RESERVED.</p>
        <div class="flex items-center gap-2">
            <span>SYS_STATUS:</span>
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
            <span class="text-green-500">ONLINE</span>
        </div>
    </footer>
</section>
