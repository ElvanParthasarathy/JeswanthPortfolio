---
import videos from '../data/videos.json';
---
<section id="work" class="py-32 relative bg-black" data-bg-color="#000000" data-text-color="#ffffff">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <h2 class="text-4xl md:text-5xl font-primary font-bold mb-16 text-center text-white tracking-tight">Theatrical Screenings</h2>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            {videos.map((video, index) => (
                <div class="apple-glass-card group relative p-3 aspect-video overflow-hidden cursor-pointer">
                    <div class="absolute inset-0 z-0 p-3 pb-0">
                        <!-- Play Button Overlay -->
                        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-20 flex justify-center items-center backdrop-blur-sm rounded-[2.5rem]">
                            <div class="w-20 h-20 rounded-full bg-white/10 backdrop-blur-md flex justify-center items-center border border-white/20 transform scale-75 group-hover:scale-100 transition-all duration-500 shadow-[0_0_40px_rgba(255,255,255,0.2)]">
                                <svg class="w-8 h-8 text-white ml-2" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                            </div>
                        </div>
                        <video 
                            src={video.local_path} 
                            class="w-full h-full object-cover rounded-[2.5rem] transform group-hover:scale-105 transition-transform duration-700 ease-out opacity-60 group-hover:opacity-100"
                            muted 
                            loop 
                            playsinline
                            onmouseover="this.play()"
                            onmouseout="this.pause()"
                        ></video>
                    </div>
                    
                    <div class="absolute bottom-6 left-6 right-6 z-30 pointer-events-none transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                        <div class="apple-glass-pill px-6 py-4 flex flex-col justify-between items-start w-full">
                            <h3 class="text-xl font-bold text-white tracking-tight drop-shadow-md">{video.title}</h3>
                            <div class="flex flex-wrap gap-2 text-xs font-semibold uppercase tracking-widest text-white/70 mt-2">
                                <span>{video.year}</span>
                                <span>•</span>
                                <span>{video.theatre}</span>
                            </div>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
