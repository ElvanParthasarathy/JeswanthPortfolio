---
---
<section id="about" class="py-32 relative overflow-hidden bg-black" data-bg-color="#000000" data-text-color="#ffffff">
    <!-- Ambient glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-white opacity-5 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-6 relative z-10">
        
        <div class="apple-glass-card p-10 md:p-16 flex flex-col md:flex-row gap-12 items-center relative overflow-hidden">
            <!-- Inner card glow -->
            <div class="absolute -top-32 -right-32 w-64 h-64 bg-white opacity-10 blur-[80px] rounded-full pointer-events-none"></div>

            <div class="w-48 h-48 rounded-full bg-white/5 border border-white/10 flex-shrink-0 flex items-center justify-center overflow-hidden backdrop-blur-md">
                <svg class="w-16 h-16 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            </div>

            <div class="space-y-6 text-center md:text-left z-10">
                <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-white">Jeswanth S <span class="text-white/40 text-2xl md:text-4xl block md:inline font-normal mt-2 md:mt-0">TJ Cutz</span></h2>
                
                <div class="space-y-2 text-white/80 text-lg">
                    <p class="font-semibold text-white">Bachelor Of Engineering</p>
                    <p>Final year ECE dept</p>
                    <p class="text-white/50 uppercase tracking-widest text-sm mt-2">RMD Engineering College</p>
                </div>
                
                <p class="text-white/60 leading-relaxed pt-4 border-t border-white/10">
                    Started in 2020 editing on mobile. Now mastering CapCut PC & Premiere Pro to create visuals that get fans screaming in theatres across Tamil Nadu.
                </p>

                <div class="flex flex-wrap gap-3 pt-4 justify-center md:justify-start">
                    <span class="apple-glass-pill px-5 py-2 text-xs font-bold tracking-widest text-white">CAPCUT PC PRO</span>
                    <span class="apple-glass-pill px-5 py-2 text-xs font-bold tracking-widest text-white">PREMIERE PRO</span>
                </div>
            </div>
            
        </div>
    </div>
</section>
