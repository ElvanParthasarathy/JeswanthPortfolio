---
---
<section id="about" class="py-32 relative overflow-hidden bg-film-bg">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-12 gap-8 items-start relative z-10">
        
        <!-- Left Panel: Profile Image Bento Box -->
        <div class="md:col-span-5 bento-item film-panel-solid p-2 rounded-[2.5rem] shadow-soft min-h-[400px] md:h-[600px] flex flex-col relative group overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-[#D4A373]/20 to-transparent z-0"></div>
            
            <div class="relative z-10 h-full w-full rounded-[2rem] overflow-hidden bg-film-panel flex items-center justify-center">
                <!-- Placeholder for actual image -->
                <div class="flex flex-col items-center justify-center text-film-dark opacity-50 transition-transform duration-700 group-hover:scale-105">
                    <svg class="w-12 h-12 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <span class="font-mono text-[10px] tracking-widest uppercase">Insert Portrait Here</span>
                </div>
            </div>
            
            <div class="absolute bottom-6 left-6 right-6 z-20 film-pill-solid px-6 py-4 flex justify-between items-center opacity-0 group-hover:opacity-100 transition-opacity duration-500 transform translate-y-4 group-hover:translate-y-0">
                <span class="font-primary font-bold text-film-text">Jeswanth S</span>
                <span class="font-mono text-[10px] text-film-accent border border-film-accent px-2 py-1 rounded-full">EST. 2020</span>
            </div>
        </div>

        <!-- Right Panels: Info & Skills Bento Boxes -->
        <div class="md:col-span-7 space-y-8 flex flex-col min-h-[400px] md:h-[600px]">
            
            <!-- Bio Box -->
            <div class="bento-item film-panel-solid p-6 sm:p-10 rounded-[2.5rem] shadow-soft flex-grow flex flex-col justify-center relative overflow-hidden">
                <div class="absolute top-0 right-0 w-64 h-64 bg-[#E9EDC9] rounded-full mix-blend-multiply filter blur-[60px] opacity-40 -translate-y-1/2 translate-x-1/4"></div>
                
                <h2 class="text-3xl font-primary font-bold text-film-text mb-6 relative z-10">The Director's Cut</h2>
                <p class="text-film-muted text-lg leading-relaxed relative z-10">
                    The creator behind the brand <span class="font-bold text-film-dark">TJ CUTZ</span>. Started in 2020 editing on mobile. Now mastering CapCut PC & Premiere Pro to create visuals that get fans screaming in theatres.
                </p>
                
                <div class="grid grid-cols-2 gap-6 mt-8 relative z-10">
                    <div>
                        <span class="block font-mono text-[10px] text-film-accent uppercase tracking-widest mb-1">Education</span>
                        <span class="block font-primary font-medium text-film-dark">B.E. ECE (Final Year)</span>
                        <span class="block font-primary text-sm text-film-muted">RMD Engineering College</span>
                    </div>
                </div>
            </div>

            <!-- Skills Box -->
            <div class="bento-item film-panel-solid p-6 sm:p-8 rounded-[2.5rem] shadow-soft flex flex-col sm:flex-row gap-4 overflow-hidden relative">
                <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-white/30 to-transparent"></div>
                
                <div class="flex-1 film-pill-solid bg-white/40 p-4 flex flex-col items-center justify-center gap-2 relative z-10 hover:bg-white/60 transition-colors">
                    <span class="font-primary font-bold text-film-text">CapCut PC</span>
                    <span class="font-mono text-[10px] text-film-accent bg-film-accent/10 px-2 py-0.5 rounded-full">PRO</span>
                </div>
                
                <div class="flex-1 film-pill-solid bg-white/40 p-4 flex flex-col items-center justify-center gap-2 relative z-10 hover:bg-white/60 transition-colors">
                    <span class="font-primary font-bold text-film-text">Premiere Pro</span>
                    <span class="font-mono text-[10px] text-film-muted border border-film-muted/30 px-2 py-0.5 rounded-full">EXPERT</span>
                </div>
            </div>
            
        </div>
    </div>
</section>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    
    gsap.registerPlugin(ScrollTrigger);

    // BENTO BOX ANIMATIONS
    gsap.from(".bento-item", {
        scrollTrigger: {
            trigger: "#about",
            start: "top 75%",
        },
        y: 40,
        opacity: 0,
        duration: 1,
        stagger: 0.15,
        ease: "power3.out"
    });
</script>
