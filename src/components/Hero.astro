---
---
<header class="relative h-screen w-full flex flex-col justify-center items-center overflow-hidden bg-film-bg">
    
    <!-- Vintage Grid Background (Solid, no glass blurs) -->
    <div class="absolute inset-0 z-0 opacity-15" style="background-size: 40px 40px; background-image: linear-gradient(to right, var(--color-film-dark) 1px, transparent 1px), linear-gradient(to bottom, var(--color-film-dark) 1px, transparent 1px);"></div>

    <!-- Main Typography Solid Panel -->
    <div class="z-10 text-center space-y-6 film-panel-solid p-6 sm:p-12 md:p-20 relative max-w-4xl mx-4">
        <!-- Film strip accents -->
        <div class="absolute top-4 left-4 right-4 h-6 film-strip-border opacity-30 rotate-90 origin-left scale-x-[0.2]"></div>
        
        <h2 class="text-film-accent tracking-[0.3em] text-xs md:text-sm font-mono uppercase font-bold reveal-text" data-i18n="hero.role">
            Cinematic Editor
        </h2>
        
        <h1 class="font-primary font-bold leading-tight tracking-tighter text-film-dark flex flex-col items-center">
            <span class="block text-5xl sm:text-6xl md:text-8xl reveal-text" data-i18n="hero.name">
                JESWANTH S
            </span>
        </h1>
        
        <div class="mt-8 pt-6 border-t border-film-dark/20 reveal-text">
            <p class="text-film-muted max-w-lg mx-auto text-sm md:text-base font-primary" data-i18n="hero.desc">
                Crafting visual stories with a modern retro twist.
            </p>
        </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 reveal-text delay-700">
        <span class="text-[10px] font-mono tracking-widest text-film-muted uppercase">Scroll to Project</span>
        <div class="w-[1px] h-12 bg-gradient-to-b from-film-accent to-transparent"></div>
    </div>
</header>

<script>
    import { gsap } from 'gsap';
    
    // TEXT REVEAL ANIMATIONS
    gsap.from(".reveal-text", {
        y: 40,
        opacity: 0,
        duration: 1.2,
        stagger: 0.15,
        ease: "power3.out",
        delay: 0.2
    });
</script>
