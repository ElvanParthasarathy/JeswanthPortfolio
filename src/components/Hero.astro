---
---
<header class="relative h-screen w-full flex flex-col justify-center items-center overflow-hidden bg-film-bg">
    
    <!-- Vintage Grid Background (Solid, no glass blurs) -->
    <div class="absolute inset-0 z-0 opacity-15" style="background-size: 40px 40px; background-image: linear-gradient(to right, var(--color-film-dark) 1px, transparent 1px), linear-gradient(to bottom, var(--color-film-dark) 1px, transparent 1px);"></div>

    <!-- Main Typography Solid Panel -->
    <div class="z-10 text-center space-y-6 film-panel-solid p-6 sm:p-12 md:p-20 relative max-w-4xl mx-4">
        <!-- Decorative Film Elements -->
        <div class="absolute inset-0 pointer-events-none overflow-hidden z-0">
            <!-- Film Reel -->
            <svg class="absolute top-10 right-10 md:top-20 md:right-32 w-32 h-32 md:w-48 md:h-48 text-film-dark opacity-10 animate-[spin_30s_linear_infinite]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.5">
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="3"></circle>
                <circle cx="12" cy="5" r="1.5"></circle>
                <circle cx="12" cy="19" r="1.5"></circle>
                <circle cx="5" cy="12" r="1.5"></circle>
                <circle cx="19" cy="12" r="1.5"></circle>
                <path d="M12 7v10M7 12h10"></path>
            </svg>

            <!-- Clapperboard -->
            <svg class="absolute bottom-20 left-10 md:bottom-32 md:left-24 w-24 h-24 md:w-40 md:h-40 text-film-dark opacity-10 -rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.5">
                <path d="M4 6h16v12H4z"></path>
                <path d="M4 6l4-4 4 4 4-4 4 4"></path>
                <path d="M4 10h16"></path>
            </svg>

            <!-- Vintage Projector / Camera -->
            <svg class="absolute top-40 left-5 md:top-32 md:left-32 w-20 h-20 md:w-32 md:h-32 text-film-dark opacity-10 rotate-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.5">
                <rect x="4" y="8" width="12" height="10" rx="1"></rect>
                <circle cx="8" cy="4" r="3"></circle>
                <circle cx="16" cy="4" r="3"></circle>
                <path d="M16 10l6-2v8l-6-2"></path>
            </svg>

            <!-- Cassette Tape -->
            <svg class="absolute bottom-10 right-20 md:bottom-24 md:right-40 w-20 h-20 md:w-28 md:h-28 text-film-dark opacity-10 rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.5">
                <rect x="3" y="6" width="18" height="12" rx="2"></rect>
                <circle cx="8" cy="12" r="1.5"></circle>
                <circle cx="16" cy="12" r="1.5"></circle>
                <path d="M10 12h4"></path>
            </svg>
        </div>

        <h2 class="text-film-accent tracking-[0.3em] text-xs md:text-sm font-mono uppercase font-bold reveal-text z-10" data-i18n="hero.role">
            Cinematic Editor
        </h2>
        
        <h1 class="font-primary font-bold leading-tight tracking-tighter text-film-dark flex flex-col items-center z-10">
            <span class="block text-5xl sm:text-6xl md:text-8xl reveal-text" data-i18n="hero.name">
                JESWANTH S
            </span>
        </h1>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 reveal-text delay-700">
        <span class="text-[10px] font-mono tracking-widest text-film-muted uppercase">Scroll to Project</span>
        <div class="w-[1px] h-12 bg-gradient-to-b from-film-accent to-transparent"></div>
    </div>
</header>

<script>
    import { gsap } from 'gsap';
    
    // TEXT REVEAL ANIMATIONS
    gsap.from(".reveal-text", {
        y: 40,
        opacity: 0,
        duration: 1.2,
        stagger: 0.15,
        ease: "power3.out",
        delay: 0.2
    });
</script>
