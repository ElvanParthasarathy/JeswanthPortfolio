---
---
<section id="contact" class="min-h-[70vh] flex flex-col justify-between py-20 px-6 relative overflow-hidden">
    <!-- Contact Section Decor -->
    <div class="absolute inset-0 pointer-events-none opacity-10 z-0">
        <!-- Reel -->
        <svg class="absolute top-[20%] left-[-5%] w-72 h-72 text-film-dark rotate-45 animate-[spin_50s_linear_infinite_reverse]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.5"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="3"></circle><circle cx="12" cy="5" r="1.5"></circle><circle cx="12" cy="19" r="1.5"></circle><circle cx="5" cy="12" r="1.5"></circle><circle cx="19" cy="12" r="1.5"></circle><path d="M12 7v10M7 12h10"></path></svg>
        <!-- Cassette -->
        <svg class="absolute bottom-[20%] right-[10%] w-48 h-48 text-film-dark -rotate-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.5"><rect x="3" y="6" width="18" height="12" rx="2"></rect><circle cx="8" cy="12" r="1.5"></circle><circle cx="16" cy="12" r="1.5"></circle><path d="M10 12h4"></path></svg>
    </div>

    <div class="max-w-4xl mx-auto w-full flex flex-col justify-center items-center text-center flex-grow film-panel-solid p-12 md:p-20 rounded-[3rem] shadow-soft relative overflow-hidden z-10">
        
        <!-- Warm glowing orb background -->
        <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none opacity-40">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-gradient-radial from-[#D4A373]/30 to-transparent mix-blend-multiply filter blur-[100px]"></div>
        </div>

        <div class="relative z-10 w-full flex flex-col items-center">
            <p class="text-film-accent font-mono text-xs md:text-sm tracking-[0.3em] mb-6 border border-film-accent/20 px-6 py-2 rounded-full bg-film-accent/5 uppercase" data-i18n="contact.collab">Let's Collaborate</p>
            
            <h2 class="text-4xl md:text-6xl font-primary font-bold tracking-tight mb-12 text-film-dark">
                <span data-i18n="contact.h2a">Ready to cut your next</span> <span class="block text-film-accent mt-2" data-i18n="contact.h2b">masterpiece?</span>
            </h2>
            
            <div class="flex flex-col sm:flex-row gap-6 w-full max-w-lg justify-center">
                <!-- Mail Button -->
                <a href="mailto:jeswanths123@gmail.com" class="flex-1 flex items-center justify-center gap-3 px-8 py-4 bg-film-accent text-white font-primary font-bold rounded-full shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
                    <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    <span data-i18n="contact.email">Email Me</span>
                </a>
                
                <!-- Instagram Button -->
                <a href="https://instagram.com/tj_cutz" target="_blank" class="flex-1 flex items-center justify-center gap-3 px-8 py-4 film-pill-solid text-film-dark font-primary font-bold hover:bg-white/60 transition-all duration-300 group">
                    <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                    <span data-i18n="contact.insta">Instagram</span>
                </a>
            </div>
        </div>
    </div>
    
    <footer class="w-full flex justify-between items-center pt-8 mt-12 border-t border-film-dark/10 text-xs font-mono text-film-muted">
        <p>&copy; {new Date().getFullYear()} <span data-i18n="contact.copy">JESWANTH SARAVANAN. ALL RIGHTS RESERVED.</span></p>
        <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-film-accent animate-pulse"></span>
            <span data-i18n="contact.avail">AVAILABLE FOR WORK</span>
        </div>
    </footer>
    
    <!-- Subtle Developer Signature (Easter Egg) -->
    <a href="https://jaiprakashpartha.vercel.app" target="_blank" rel="noopener noreferrer" class="absolute bottom-2 left-1/2 -translate-x-1/2 text-[10px] font-mono opacity-5 hover:opacity-100 transition-opacity duration-500 text-film-dark flex items-center gap-1 z-50 mix-blend-multiply">
        Built with <span class="text-red-500/80">❤️</span> by Elvan Parthasarathy
    </a>
</section>
