---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=JetBrains+Mono:wght@400;700&family=Mukta+Malar:wght@400;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="selection:bg-film-accent selection:text-white relative bg-film-bg min-h-screen">
		<!-- Global Vintage Grid Background -->
		<div class="fixed inset-0 z-0 opacity-15 pointer-events-none" style="background-size: 40px 40px; background-image: linear-gradient(to right, var(--color-film-dark) 1px, transparent 1px), linear-gradient(to bottom, var(--color-film-dark) 1px, transparent 1px);"></div>

		<div class="film-grain"></div>

		<!-- Global Scattered SVG Decorations -->
		<div class="fixed inset-0 pointer-events-none overflow-hidden z-0 opacity-10">
			<!-- TOP LEFT -->
			<svg class="absolute top-[5%] -left-10 w-64 h-64 text-film-dark animate-[spin_40s_linear_infinite]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.5"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="3"></circle><circle cx="12" cy="5" r="1.5"></circle><circle cx="12" cy="19" r="1.5"></circle><circle cx="5" cy="12" r="1.5"></circle><circle cx="19" cy="12" r="1.5"></circle><path d="M12 7v10M7 12h10"></path></svg>
			<!-- TOP RIGHT -->
			<svg class="absolute top-[15%] right-[5%] w-48 h-48 text-film-dark rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.5"><rect x="4" y="8" width="12" height="10" rx="1"></rect><circle cx="8" cy="4" r="3"></circle><circle cx="16" cy="4" r="3"></circle><path d="M16 10l6-2v8l-6-2"></path></svg>
			<!-- MIDDLE LEFT -->
			<svg class="absolute top-[45%] left-[10%] w-72 h-72 text-film-dark -rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.5"><path d="M4 6h16v12H4z"></path><path d="M4 6l4-4 4 4 4-4 4 4"></path><path d="M4 10h16"></path></svg>
			<!-- MIDDLE RIGHT -->
			<svg class="absolute top-[60%] -right-16 w-80 h-80 text-film-dark rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.5"><rect x="3" y="6" width="18" height="12" rx="2"></rect><circle cx="8" cy="12" r="1.5"></circle><circle cx="16" cy="12" r="1.5"></circle><path d="M10 12h4"></path></svg>
			<!-- BOTTOM LEFT -->
			<svg class="absolute bottom-[10%] -left-12 w-56 h-56 text-film-dark -rotate-12 animate-[spin_50s_linear_infinite_reverse]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.5"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="3"></circle><circle cx="12" cy="5" r="1.5"></circle><circle cx="12" cy="19" r="1.5"></circle><circle cx="5" cy="12" r="1.5"></circle><circle cx="19" cy="12" r="1.5"></circle><path d="M12 7v10M7 12h10"></path></svg>
			<!-- BOTTOM RIGHT -->
			<svg class="absolute bottom-[5%] right-[15%] w-48 h-48 text-film-dark -rotate-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.5"><rect x="4" y="8" width="12" height="10" rx="1"></rect><circle cx="8" cy="4" r="3"></circle><circle cx="16" cy="4" r="3"></circle><path d="M16 10l6-2v8l-6-2"></path></svg>
		</div>

		<div class="cursor-dot z-50"></div>

		<!-- Main Content Wrapper to sit above the fixed background -->
		<div class="relative z-10">
			<slot />
		</div>

		<script>
			import { gsap } from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';
			gsap.registerPlugin(ScrollTrigger);

			// Language Toggle Logic
			import en from '../data/en.json';
			import ta from '../data/ta.json';
			import ta_latn from '../data/ta_latn.json';
			const dict: Record<string, Record<string, string>> = { en, ta, ta_latn };

			const savedLang = localStorage.getItem('portfolio-lang') || 'en';
			document.body.setAttribute('data-lang', savedLang);

			window.toggleLanguage = () => {
				const currentLang = document.body.getAttribute('data-lang');
				let newLang = 'en';
				if (currentLang === 'en') newLang = 'ta';
				else if (currentLang === 'ta') newLang = 'ta_latn';
				else if (currentLang === 'ta_latn') newLang = 'en';
				
				document.body.setAttribute('data-lang', newLang);
				localStorage.setItem('portfolio-lang', newLang);
				document.dispatchEvent(new CustomEvent('languageChanged', { detail: newLang }));
			};

			document.addEventListener('languageChanged', (e: any) => {
				const lang = e.detail;
				document.querySelectorAll('[data-i18n]').forEach((el) => {
					const key = el.getAttribute('data-i18n');
					if(key && dict[lang] && dict[lang][key]) {
						el.textContent = dict[lang][key];
					}
				});
				
				// Optional: update fonts if needed based on language
				if(lang === 'ta') {
					document.body.classList.add('font-ta');
				} else {
					document.body.classList.remove('font-ta');
				}
			});

			// Hydrate on load
			if(savedLang === 'ta') {
				// Use setTimeout to ensure DOM is fully parsed
				setTimeout(() => {
					document.dispatchEvent(new CustomEvent('languageChanged', { detail: 'ta' }));
				}, 50);
			}

			// Custom Cursor Logic
			const cursorDot = document.querySelector('.cursor-dot') as HTMLElement;
			
			if (cursorDot) {
				window.addEventListener('mousemove', (e) => {
					const posX = e.clientX;
					const posY = e.clientY;

					gsap.to(cursorDot, {
						x: posX,
						y: posY,
						duration: 0.1,
						ease: "power2.out"
					});
				});
			}
		</script>
	</body>
</html>
