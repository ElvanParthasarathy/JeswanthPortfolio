---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=JetBrains+Mono:wght@400;700&family=Mukta+Malar:wght@400;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="selection:bg-film-accent selection:text-white relative bg-film-bg min-h-screen">
		<!-- Global Vintage Grid Background (Fixed to cover viewport seamlessly) -->
		<div class="fixed inset-0 z-0 opacity-15 pointer-events-none" style="background-size: 40px 40px; background-image: linear-gradient(to right, var(--color-film-dark) 1px, transparent 1px), linear-gradient(to bottom, var(--color-film-dark) 1px, transparent 1px);"></div>

		<div class="film-grain"></div>

		<div class="cursor-dot z-50"></div>

		<!-- Main Content Wrapper to sit above the fixed background -->
		<div class="relative z-10">
			<slot />
		</div>

		<script>
			import { gsap } from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';
			gsap.registerPlugin(ScrollTrigger);

			// Language Toggle Logic
			import en from '../data/en.json';
			import ta from '../data/ta.json';
			import ta_latn from '../data/ta_latn.json';
			const dict: Record<string, Record<string, string>> = { en, ta, ta_latn };

			const savedLang = localStorage.getItem('portfolio-lang') || 'en';
			document.body.setAttribute('data-lang', savedLang);

			window.toggleLanguage = () => {
				const currentLang = document.body.getAttribute('data-lang');
				let newLang = 'en';
				if (currentLang === 'en') newLang = 'ta';
				else if (currentLang === 'ta') newLang = 'ta_latn';
				else if (currentLang === 'ta_latn') newLang = 'en';
				
				document.body.setAttribute('data-lang', newLang);
				localStorage.setItem('portfolio-lang', newLang);
				document.dispatchEvent(new CustomEvent('languageChanged', { detail: newLang }));
			};

			document.addEventListener('languageChanged', (e: any) => {
				const lang = e.detail;
				document.querySelectorAll('[data-i18n]').forEach((el) => {
					const key = el.getAttribute('data-i18n');
					if(key && dict[lang] && dict[lang][key]) {
						el.textContent = dict[lang][key];
					}
				});
				
				// Optional: update fonts if needed based on language
				if(lang === 'ta') {
					document.body.classList.add('font-ta');
				} else {
					document.body.classList.remove('font-ta');
				}
			});

			// Hydrate on load
			if(savedLang === 'ta') {
				// Use setTimeout to ensure DOM is fully parsed
				setTimeout(() => {
					document.dispatchEvent(new CustomEvent('languageChanged', { detail: 'ta' }));
				}, 50);
			}

			// Custom Cursor Logic
			const cursorDot = document.querySelector('.cursor-dot') as HTMLElement;
			
			if (cursorDot) {
				window.addEventListener('mousemove', (e) => {
					const posX = e.clientX;
					const posY = e.clientY;

					gsap.to(cursorDot, {
						x: posX,
						y: posY,
						duration: 0.1,
						ease: "power2.out"
					});
				});
			}
		</script>
	</body>
</html>
